@page "/gamedetails/{id}"

@if ((game == null) || (game.Reviews == null))
{
    <p>Loading...</p>
}
else
{
    <div class="container row mt-5">
        <div class="col-6">
            <iframe width="560" height="350" src="@game.TrailerLink" title="YouTube video player" frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen>
            </iframe>
        </div>
        <div class="col-6">
            <h3>@game.Title</h3>
            <p>@game.Description</p>
            <AuthorizeView>
                <Authorized>
                    <button class="btn btn-primary" @onclick="AddShoppingCartItem">Buy</button>
                </Authorized>
            </AuthorizeView>
        </div>
        <div class="col-12 mt-5">
            @foreach (var review in game.Reviews)
            {
                <p>@review.Content</p>
            }
        </div>
    </div>
}